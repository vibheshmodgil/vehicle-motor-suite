# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- App-generated / local state (not part of the source code) ---
# Standard-motor library the app writes to on save (your personal data).
std_motor_data_sample.json
# Chat log from the Assistant sidebar (your personal Q&A history).
assistant_chat_log.jsonl
# Sample Excel/report files regenerated by `python generate_sample_data.py`.
sample_data/
# Assistant's local vector index (regenerated with "Rebuild Knowledge Base").
knowledge_base/.index/

# --- Reference documents you drop in for the Assistant to read ---
# These may be licensed/proprietary (datasheets, standards, product docs) and
# shouldn't be redistributed by default. Remove/adjust these lines if you're
# sure you have the right to share what you put in these folders.
knowledge_base/standards/*
knowledge_base/datasheets/*
knowledge_base/products/*
knowledge_base/scenarios/*
!knowledge_base/standards/.gitkeep
!knowledge_base/datasheets/.gitkeep
!knowledge_base/products/.gitkeep
!knowledge_base/scenarios/.gitkeep

# --- Optional brand assets (may be a company's logo/trademark) ---
tvs_logo.webp
motor.jpg
